{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "monorepo-template",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "clean": "turbo run clean && rm -rf .turbo .pnpm-store",
    "dev": "turbo run dev",
    "dev:setup": "pnpm install && pnpm db:up && pnpm db:migrate && pnpm db:generate",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "start": "turbo run start",
    "biome:lint": "biome lint",
    "biome:format": "biome format --write",
    "biome:check": "biome check --write",
    "db:up": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:clean": "docker compose down -v",
    "db:generate": "pnpm --filter @packages/db exec prisma generate",
    "db:migrate": "pnpm --filter @packages/db exec prisma migrate dev"
  },
  "packageManager": "pnpm@11.10.0",
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
